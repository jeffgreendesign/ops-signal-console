{
  "name": "ops-signal-console",
  "version": "0.1.0",
  "private": true,
  "description": "Synthetic portfolio signal triage console prototype.",
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "tsc -p tsconfig.json && vite build",
    "preview": "vite preview --host 127.0.0.1",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "scan:public-safety": "node scripts/scan-public-safety.mjs"
  },
  "keywords": [
    "ops",
    "ai",
    "prototype",
    "triage",
    "signals",
    "portfolio",
    "risk",
    "controls"
  ],
  "license": "MIT",
  "devDependencies": {
    "@types/node": "latest",
    "typescript": "latest",
    "vite": "latest",
    "vitest": "latest"
  }
}
